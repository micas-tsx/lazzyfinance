# Telegram Bot Token
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Supabase Connection (Transaction mode recommended)
# Use o formato postgresql://usuario:senha@host:6543/postgres?pgbouncer=true
DATABASE_URL=seu_url_supabase_aqui

# Google Gemini API Key
GEMINI_API_KEY=sua_chave_gemini_aqui

# Web Server Configuration
# Porta onde a API (backend) vai rodar
WEB_PORT=3001
# URL base do dashboard (frontend)
WEB_BASE_URL=http://localhost:5173
